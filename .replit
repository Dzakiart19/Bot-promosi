modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "OpenTalk Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Yapping Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SillyChat Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Chatib Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "DuckChat Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "X Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Telegram Bot"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "TemanID Bot"

[[workflows.workflow]]
name = "OpenTalk Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8000 node bot/opentalk-bot.js"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Yapping Bot"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3002 node bot/yapping-bot.js"
waitForPort = 3002

[[workflows.workflow]]
name = "SillyChat Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 node bot/silly-bot.js"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Chatib Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3003 node bot/chatib-bot.js"
waitForPort = 3003

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "DuckChat Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3004 node bot/duckchat-bot.js"
waitForPort = 3004

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "X Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3005 node bot/x-bot.js"
waitForPort = 3005

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Telegram Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 node bot/telegram-bot.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "TemanID Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3006 node bot/temanid-bot.js"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 3003
externalPort = 3003

[[ports]]
localPort = 3004
externalPort = 3004

[[ports]]
localPort = 3005
externalPort = 3005

[[ports]]
localPort = 3006
externalPort = 3000

[[ports]]
localPort = 4200
externalPort = 4200

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "bot/start-all.js"]
